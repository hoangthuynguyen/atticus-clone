# =============================================================================
# Atticus Backend - Environment Variables
# Copy to .env and fill in values
# =============================================================================

# Server
PORT=3000
NODE_ENV=development
# Your Cloudflare Pages URL (set in Render env vars for CORS)
FRONTEND_URL=https://your-project.pages.dev

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Supabase (from supabase.com project settings)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cloudflare R2 (from Cloudflare Dashboard > R2 > API Tokens)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=atticus-exports
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Upstash Redis (from upstash.com console)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Export settings
MAX_EXPORT_SIZE_MB=50
SIGNED_URL_EXPIRY_HOURS=24
